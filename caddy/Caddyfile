{
	# Disable Caddy's automatic HTTPS / Let's Encrypt — we use Cloudflare Origin CA
	# certificate (15-year validity, free from CF dashboard). Caddy only listens on
	# 443 for inbound traffic; CF orange-cloud handles edge TLS for clients.
	auto_https disable_certs

	# Trust X-Forwarded-* headers ONLY from Cloudflare. UFW already restricts
	# inbound 443 to these ranges at the host level — this is defense in
	# depth so a UFW misconfig can't enable CF-Connecting-IP spoofing.
	#
	# CIDR list mirrors https://www.cloudflare.com/ips-v4 and /ips-v6.
	# infrastructure/ufw-cloudflare.sh refreshes UFW from the same source.
	# When Cloudflare rotates ranges (rare, ~yearly), update both files.
	servers {
		trusted_proxies static \
 173.245.48.0/20 \
 103.21.244.0/22 \
 103.22.200.0/22 \
 103.31.4.0/22 \
 141.101.64.0/18 \
 108.162.192.0/18 \
 190.93.240.0/20 \
 188.114.96.0/20 \
 197.234.240.0/22 \
 198.41.128.0/17 \
 162.158.0.0/15 \
 104.16.0.0/13 \
 104.24.0.0/14 \
 172.64.0.0/13 \
 131.0.72.0/22 \
 2400:cb00::/32 \
 2606:4700::/32 \
 2803:f800::/32 \
 2405:b500::/32 \
 2405:8100::/32 \
 2a06:98c0::/29 \
 2c0f:f248::/32
		trusted_proxies_strict
		client_ip_headers CF-Connecting-IP X-Forwarded-For
		# Disable Caddy's auto strict SNI/Host match (triggered by
		# client_auth) — mTLS is the real auth, SNI/Host mismatch is fine.
		strict_sni_host insecure_off
	}

	# Structured logs to stdout for Vector → Axiom pickup.
	log default {
		output stdout
		format json
	}
}

# Shared TLS + headers + access-log block reused across all hostnames.
# Empty `log` directive opts the site into Caddy's HTTP access log, routed
# through the global `default` logger (stdout/json) defined above. Without
# this, Caddy only emits admin-API logs — no per-request observability.
(common_tls) {
	tls /etc/caddy/origin.crt /etc/caddy/origin.key {
		protocols tls1.2 tls1.3
		client_auth {
			mode require_and_verify
			trust_pool file /etc/caddy/cf-aop-zone-ca.crt
		}
	}
	log
	header {
		-Server
	}
}

# Compose one branded error page (beta): when the origin self-describes
# an error (X-Error-Code) and the client meaningfully asked for HTML,
# swap the body for the Next error page while KEEPING the origin status
# (the inner proxy would otherwise answer with Next's 200). JSON clients
# and Accept:*/* scanner probes get the origin response untouched —
# composition costs a Next render. args[0] = the status code.
(compose_beta_err) {
	@err{args[0]} {
		status {args[0]}
		header X-Error-Code *
	}
	handle_response @err{args[0]} {
		@html{args[0]} {
			header Accept *text/html*
			method GET HEAD
		}
		handle @html{args[0]} {
			rewrite * /_error/{args[0]}?code={rp.header.X-Error-Code}&from={uri}
			reverse_proxy spoo_next_beta:3000 {
				@ok{args[0]} status 2xx
				replace_status @ok{args[0]} {args[0]}
				header_up Host {host}
			}
		}
		handle {
			copy_response
		}
	}
}

spoo.me, www.spoo.me {
	import common_tls
	reverse_proxy app:8000 {
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}
	}
}

# Beta slice (edge-cache rollout rung 3+). Runs as its own compose
# project (docker-compose.beta.yml) on the shared network — resolved by
# container name, not compose service name.
beta.spoo.me {
	import common_tls

	# BETA-ONLY (do not port to prod): beta is a duplicate of the whole
	# site — never let crawlers index it. Wins over the matchers below
	# because handle is ordered before reverse_proxy.
	@robots path /robots.txt
	handle @robots {
		header Content-Type "text/plain; charset=utf-8"
		respond "User-agent: *
Disallow: /" 200
	}

	# Only paths with a built Next page belong here — a listed path
	# with no page behind it 404s in Next instead of falling through
	# to FastAPI.
	@next {
		path /
		path /about /about/*
		path /pricing /pricing/*
		path /apps /apps/*
		path /testimonials /testimonials/*
		path /contact /report
		path /login /signup /forgot-password
		path /onboarding /onboarding/*
		path /privacy /terms /legal
		path /relay/*
		path /dashboard /dashboard/*
		# Composed-error URL (Next rewrites it to error-pages/ internally).
		path /_error/*
		path /_next/* /icon.png
		path /favicon.ico /favicon.png /favicon.svg
		# Next public/ asset dirs + the favicon-proxy route. A new top-level
		# dir under public/ needs a line here AND a reserved-aliases entry,
		# or it 404s through FastAPI and takes client pages down with it.
		path /geo/* /brand/* /icons-3d/*
		path /api/favicon
		# SEO files (robots.ts/sitemap.ts generators + public/ text files).
		# Exact .well-known path only — the rest of that namespace stays
		# with the backend for whatever claims it later.
		path /robots.txt /sitemap.xml /humans.txt
		path /security.txt /.well-known/security.txt
	}
	reverse_proxy @next spoo_next_beta:3000 {
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}
		header_up Host {host}
	}

	# Stats pages are GET-only in Next: POST /stats/{code} is the legacy
	# public JSON API and POST /stats the legacy form handler — both keep
	# falling through to FastAPI forever. (An unscoped /stats/* matcher
	# served API consumers 200+HTML — caught on beta.)
	@next_stats {
		method GET HEAD
		path /stats /stats/*
	}
	reverse_proxy @next_stats spoo_next_beta:3000 {
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}
		header_up Host {host}
	}

	# /{code}+ preview — any single segment ending in + (matched against
	# the DECODED path, so emoji aliases land here too). No valid alias
	# contains +, so this can never shadow a real code.
	@preview path_regexp ^/[^/]+\+$
	reverse_proxy @preview spoo_next_beta:3000 {
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}
		header_up Host {host}
	}

	# Everything else: short codes, /auth/*, /oauth/*, /api/v1/*, /static/*
	reverse_proxy spoo_app_beta:8000 {
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}

		import compose_beta_err 404
		import compose_beta_err 410
		import compose_beta_err 429
		import compose_beta_err 451
		import compose_beta_err 500
	}
}

qr.spoo.me {
	import common_tls
	reverse_proxy qr:8080 {
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}
	}
}

# Custom-domain catch-all. CF SaaS terminates TLS at the edge, then
# dispatches to this listener via the zone fallback_origin
# (proxy-fallback.spoo.me) with SNI = proxy-fallback.spoo.me and Host
# = customer fqdn. AOP client cert gates origin access; the app reads
# the Host header to scope the lookup to the right tenant.
:443 {
	tls /etc/caddy/origin.crt /etc/caddy/origin.key {
		protocols tls1.2 tls1.3
		client_auth {
			mode require_and_verify
			trust_pool file /etc/caddy/cf-aop-zone-ca.crt
		}
	}
	log
	header {
		-Server
	}
	reverse_proxy app:8000 {
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}
	}
}
